EVALUATE
	SELECTCOLUMNS(
		FILTER(
			SUMMARIZECOLUMNS(
				DIM_DATE[YM_DATE],
				SALE_TYPE[SALE_TYPE],
				DIM_CHANNEL[ONLINE_CHANNEL],
				DIM_PRODUCT[DIVISION_GROUP],
				BRAND_SITE[SITEID],
				BRAND_SITE[BU],
				"order_oms", COALESCE(
					METRICS[00_ORDERS_OMS],
					0
				),
				"order_pos", COALESCE(
					METRICS[00_ORDERS_POS],
					0
				),
				"gmv", COALESCE(
					METRICS[01_GMV],
					0
				),
				"gross_sale", COALESCE(
					METRICS[01_GROSS_SALES],
					0
				),
				"net_sale", COALESCE(
					METRICS[01_NET_SALES],
					0
				),
				"net_sale_hyper", COALESCE(
					METRICS[01_NET_SALES_HYPER],
					0
				),
				"front_margin_number", COALESCE(
					METRICS[01_MARGIN],
					0
				)
			),
			-- WHERE
			DIM_DATE[YM_DATE] >= "2025-01-16"
			&& DIM_DATE[YM_DATE] <= "2025-01-15"
			&& LOWER(SALE_TYPE[SALE_TYPE]) <> "all"
			&& LOWER(BRAND_SITE[BU]) = "hyper"
			&& LOWER(DIM_PRODUCT[DIVISION_GROUP]) IN {
				"dry food",
				"fresh food",
				"hba and cosmetic",
				"non-food"
			}
			&& NOT (
			LOWER(DIM_CHANNEL[ONLINE_CHANNEL]) IN {
				"hyper",
				"tops"
			}
			)
		),
		-- SELECT AS
		"ds", DIM_DATE[YM_DATE],
		"sale_type", SALE_TYPE[SALE_TYPE],
		"channel", DIM_CHANNEL[ONLINE_CHANNEL],
		"channel_mapping", SWITCH(
			LOWER(DIM_CHANNEL[ONLINE_CHANNEL]),
			"app", "App",
			"tele", "Tele",
			"grab", "Grab",
			"zalo", "Zalo",
			DIM_CHANNEL[NAME_IN_USE]
		),
		"division", DIM_PRODUCT[DIVISION_GROUP],
		"division_mapping", SWITCH(
			LOWER(DIM_PRODUCT[DIVISION_GROUP]),
			"dry food", "Dry",
			"fresh food", "Fresh",
			"hba and cosmetic", "HBA",
			"non-food", "Non-Food",
			DIM_PRODUCT[DIVISION_GROUP]
		),
		"region", SWITCH(
			VALUE(BRAND_SITE[SITEID]),
			108, "Ho Chi Minh",
			102, "Ho Chi Minh",
			115, "Ho Chi Minh",
			122, "Ho Chi Minh",
			123, "Ho Chi Minh",
			101, "Ho Chi Minh",
			121, "Ho Chi Minh",
			111, "Ho Chi Minh",
			103, "South",
			133, "South",
			120, "South",
			142, "South",
			140, "South",
			137, "South",
			143, "South",
			152, "South",
			107, "Central",
			126, "Central",
			109, "Central",
			141, "Central",
			130, "Central",
			112, "Central",
			129, "Central",
			139, "Central",
			153, "Central",
			104, "Ha Noi",
			113, "Ha Noi",
			116, "Ha Noi",
			144, "Ha Noi",
			124, "Ha Noi",
			119, "Ha Noi",
			131, "Ha Noi",
			146, "Ha Noi",
			155, "Ha Noi",
			151, "Ha Noi",
			106, "North",
			128, "North",
			118, "North",
			114, "North",
			117, "North",
			125, "North",
			145, "North",
			154, "North",
			BRAND_SITE[SITEID]
		),
		"site_id", BRAND_SITE[SITEID],
		// "bu",                  BRAND_SITE[BU],
		"site_code", SWITCH(
			VALUE(BRAND_SITE[SITEID]),
			108, "gvp",
			102, "alc",
			115, "thp",
			122, "tch",
			123, "dan",
			101, "dni",
			121, "bdg",
			111, "pth",
			103, "mdg",
			133, "ntt",
			120, "cto",
			142, "bte",
			140, "tvh",
			137, "mto",
			143, "bra",
			152, "blu",
			107, "dng",
